{
  "name": "at_project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:e2e": "playwright test --project=ui-chromium",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:all": "playwright test --workers=1",
    "test:smoke": "playwright test --grep \"@smoke\" --workers=1",
    "test:regression": "playwright test --grep \"@regression\" --workers=1",
    "test:ui:smoke": "playwright test --project=ui-chromium --grep \"@smoke\"",
    "test:ui:regression": "playwright test --project=ui-chromium --grep \"@regression\"",
    "test:api:smoke": "playwright test --project=api --grep \"@smoke\"",
    "test:api:regression": "playwright test --project=api --grep \"@regression\"",
    "test:e2e:headed": "playwright test --project=ui-chromium --headed",
    "test:e2e:ui": "playwright test --project=ui-chromium --ui",
    "report:e2e": "playwright show-report",
    "report:allure": "allure generate ./allure-results --clean -o ./allure-report",
    "report:allure:open": "allure open ./allure-report",
    "report:merge": "playwright merge-reports --reporter html ./blob-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1"
  }
}
